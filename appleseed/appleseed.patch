diff --git a/src/appleseed/main/allocator.cpp b/src/appleseed/main/allocator.cpp
--- a/src/appleseed/main/allocator.cpp
+++ b/src/appleseed/main/allocator.cpp
@@ -58,6 +58,7 @@
 #include <cassert>
 #include <cstdint>
 #include <cstdio>
+#include <cstdlib>
 #include <cstring>
 #include <ctime>
 #include <exception>
@@ -501,7 +502,14 @@
         if (size < 1)
             size = 1;
 
-        void* ptr = aligned_malloc(size, MemoryAlignment);
+        /* BRL-CAD PATCH: use plain malloc (already 16-byte aligned on x64)
+         * instead of aligned_malloc.  This operator new/delete override only
+         * applies inside appleseed.dll, so std::strings/objects allocated by the
+         * default CRT allocator in other modules (art.exe, brl-cad DLLs,
+         * msvcp140d) and freed here would hit aligned_free() on a non-aligned
+         * block and crash (seen in foundation::SearchPaths::do_to_string at
+         * render start).  malloc/free keep every module on one shared CRT heap. */
+        void* ptr = malloc(size);
 
         if (!ptr)
             throw std::bad_alloc();
@@ -514,7 +522,7 @@
         if (!ptr)
             return;
 
-        aligned_free(ptr);
+        free(ptr);
     }
 }
 
