if (NOT DEFINED BEXT_SOURCE_DIR)
  message(FATAL_ERROR "BEXT_SOURCE_DIR is required")
endif()
if (NOT DEFINED BEXT_DOC_MODE)
  set(BEXT_DOC_MODE CHECK)
endif()

include("${BEXT_SOURCE_DIR}/CMake/BextDependencyInventory.cmake")
bext_collect_dependency_inventory("${BEXT_SOURCE_DIR}")

set(generated "<!-- BEGIN GENERATED PROJECT TABLE -->\n")
string(APPEND generated "<!-- Generated by CMake/GenerateDependencyDocs.cmake; do not edit this block. -->\n")
string(APPEND generated "| Project | `USE_*` group(s) | Output | Dependencies | Source |\n")
string(APPEND generated "| --- | --- | --- | --- | --- |\n")
foreach(project ${BEXT_INVENTORY_PROJECTS})
  bext_inventory_get(groups "${project}" GROUPS)
  bext_inventory_get(output_class "${project}" OUTPUT)
  bext_inventory_get(deps "${project}" DEPS)
  bext_inventory_get(urls "${project}" SOURCE_URLS)
  if (groups STREQUAL "always considered")
    set(group_text "always considered")
  else()
    set(group_text "")
    foreach(group ${groups})
      if (group_text)
        string(APPEND group_text ", ")
      endif()
      string(APPEND group_text "`USE_${group}`")
    endforeach()
  endif()
  if (deps)
    set(dep_text "")
    foreach(dep ${deps})
      if (dep_text)
        string(APPEND dep_text ", ")
      endif()
      string(APPEND dep_text "`${dep}`")
    endforeach()
  else()
    set(dep_text "—")
  endif()
  list(GET urls 0 primary_url)
  string(APPEND generated "| `${project}` | ${group_text} | `${output_class}` | ${dep_text} | [repository](${primary_url}) |\n")
endforeach()
string(APPEND generated "<!-- END GENERATED PROJECT TABLE -->")

set(doc "${BEXT_SOURCE_DIR}/DEPENDENCIES.md")
file(READ "${doc}" current)
set(begin "<!-- BEGIN GENERATED PROJECT TABLE -->")
set(end "<!-- END GENERATED PROJECT TABLE -->")
string(FIND "${current}" "${begin}" begin_pos)
string(FIND "${current}" "${end}" end_pos)
if (begin_pos EQUAL -1 OR end_pos EQUAL -1 OR end_pos LESS begin_pos)
  message(FATAL_ERROR "DEPENDENCIES.md is missing generated table markers")
endif()
string(LENGTH "${end}" end_len)
math(EXPR suffix_pos "${end_pos} + ${end_len}")
string(SUBSTRING "${current}" 0 ${begin_pos} prefix)
string(SUBSTRING "${current}" ${suffix_pos} -1 suffix)
set(expected "${prefix}${generated}${suffix}")

if (BEXT_DOC_MODE STREQUAL "WRITE")
  file(WRITE "${doc}" "${expected}")
  message(STATUS "Updated ${doc}")
elseif(BEXT_DOC_MODE STREQUAL "CHECK")
  if (NOT current STREQUAL expected)
    message(FATAL_ERROR "DEPENDENCIES.md is stale; run the update_dependency_docs target")
  endif()
  message(STATUS "Dependency metadata and DEPENDENCIES.md are valid")
else()
  message(FATAL_ERROR "Unknown BEXT_DOC_MODE ${BEXT_DOC_MODE}; expected CHECK or WRITE")
endif()
