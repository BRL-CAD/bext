+        instanceRefs_t::cvector * refs = _fwdInstanceRefs.find( queue[current++] );
+        if( !refs ) continue;
+        instanceRefs_t::cvector::const_iterator ref = refs->begin();
+        for( ; ref != refs->end(); ++ref ) {
+            if( closure.insert( *ref ).second ) queue.push_back( *ref );
