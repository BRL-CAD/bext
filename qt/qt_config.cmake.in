set(CONFIG_FILE configure)
set(ENV_VARS)
set(CONFIG_EXTRA_OPTS)

# Windows uses a different file
if (WIN32)
  set(CONFIG_FILE configure.bat)
endif (WIN32)

# If we're not on Windows, set some environment variables
if (NOT WIN32)
  set(ENV{LD_LIBRARY_PATH} "@CMAKE_BUNDLE_INSTALL_PREFIX@/@LIB_DIR@")
  set(ENV{CPPFLAGS} "-I@CMAKE_BUNDLE_INSTALL_PREFIX@/@INCLUDE_DIR@")
  set(ENV{LDFLAGS} "-L@CMAKE_BUNDLE_INSTALL_PREFIX@/@LIB_DIR@")
endif (NOT WIN32)

# Qt has its own solution for zlib and png - rather than trying to
# coax it into using ours, just go with their solution:
# https://doc.qt.io/qt-6/configure-options.html
set(CONFIG_EXTRA_OPTS ${CONFIG_EXTRA_OPTS} -qt-zlib -qt-libpng)

# QFileSystemWatcher selects kqueue in its C++ platform dispatch on FreeBSD.
# If the optional inotify compatibility headers are installed, however, Qt's
# feature probe enables inotify and its CMake source list omits the kqueue
# implementation.  Keep the feature result aligned with the backend Qt will
# actually use.  Other platforms retain Qt's normal autodetection.
if ("${BEXT_QT_TARGET_SYSTEM_NAME}" STREQUAL "FreeBSD")
  list(APPEND CONFIG_EXTRA_OPTS -no-feature-inotify)
endif ()

if ("${CMAKE_BUILD_TYPE}" STREQUAL "" OR "${CMAKE_BUILD_TYPE}" STREQUAL "Debug")
  set(QT_EXPECTED_BUILD_TYPE "Debug")
  set(QT_EXPECTED_DEBUG "ON")
  set(QT_CONFIG_OPTS "-debug")
elseif ("${CMAKE_BUILD_TYPE}" STREQUAL "Release")
  set(QT_EXPECTED_BUILD_TYPE "Release")
  set(QT_EXPECTED_DEBUG "OFF")
  set(QT_CONFIG_OPTS "-release")
else ()
  message(WARNING "Unexpected CMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE} preparing Qt6")
endif ("${CMAKE_BUILD_TYPE}" STREQUAL "" OR "${CMAKE_BUILD_TYPE}" STREQUAL "Debug")

# Qt caches command-line feature choices separately from CMAKE_BUILD_TYPE.  If
# a build directory previously configured for the other build type is reused,
# FEATURE_debug can remain forced to a value whose condition is now false.
# Clear only Qt's generated CMake configuration state when the two disagree;
# compiled objects can still be reused whenever they remain compatible.
set(qt_cache "@QT_BUILD_DIR@/CMakeCache.txt")
set(qt_cache_stale OFF)
if (EXISTS "${qt_cache}" AND DEFINED QT_EXPECTED_BUILD_TYPE)
  file(STRINGS "${qt_cache}" qt_cached_build_type_line REGEX "^CMAKE_BUILD_TYPE:[^=]*=")
  if (qt_cached_build_type_line)
    string(REGEX REPLACE "^[^=]*=" "" qt_cached_build_type "${qt_cached_build_type_line}")
    if (NOT qt_cached_build_type STREQUAL QT_EXPECTED_BUILD_TYPE)
      set(qt_cache_stale ON)
    endif ()
  endif ()

  file(STRINGS "${qt_cache}" qt_cached_debug_line REGEX "^FEATURE_debug:[^=]*=")
  if (qt_cached_debug_line)
    string(REGEX REPLACE "^[^=]*=" "" qt_cached_debug "${qt_cached_debug_line}")
    if (NOT qt_cached_debug STREQUAL QT_EXPECTED_DEBUG)
      set(qt_cache_stale ON)
    endif ()
  endif ()
endif ()

if (qt_cache_stale)
  message(STATUS
    "Resetting stale Qt configuration for CMAKE_BUILD_TYPE=${QT_EXPECTED_BUILD_TYPE}")
  file(REMOVE "${qt_cache}")
  file(REMOVE_RECURSE "@QT_BUILD_DIR@/CMakeFiles")
endif ()

execute_process(COMMAND @QT_SOURCE_DIR@/${CONFIG_FILE} ${CONFIG_EXTRA_OPTS} ${QT_CONFIG_OPTS} --prefix=@CMAKE_BUNDLE_INSTALL_PREFIX@ RESULT_VARIABLE QT_RET WORKING_DIRECTORY @QT_BUILD_DIR@ OUTPUT_VARIABLE MSG ERROR_VARIABLE MSG)

if (QT_RET)
  message(FATAL_ERROR "Qt configure failed: ${MSG}\n")
endif (QT_RET)

# See if we are building sans GUI, requires defining QT_ALLOW_HEADLESS
#
# Normalize: check cmake or env var for setting.
if (NOT DEFINED QT_ALLOW_HEADLESS AND DEFINED ENV{QT_ALLOW_HEADLESS})
  set(QT_ALLOW_HEADLESS "$ENV{QT_ALLOW_HEADLESS}")
endif()

# Read a cache bool from Qt's build cache
macro(qt_cache_check NAME OUT)
  if (EXISTS "${qt_cache}")
    file(STRINGS "${qt_cache}" _line REGEX "^${NAME}:[^=]*=")
    if (_line)
      string(REGEX REPLACE "^[^=]*=" "" _val "${_line}")
      set(${OUT} "${_val}")
    else()
      set(${OUT} "")
    endif()
  else()
    set(${OUT} "")
  endif()
endmacro()

# check GUI module + platform backends
qt_cache_check("FEATURE_gui"             feature_gui)
qt_cache_check("FEATURE_xcb"             feature_xcb)
qt_cache_check("FEATURE_wayland_client"  feature_wayland_client)
qt_cache_check("FEATURE_direct2d"        feature_direct2d)
qt_cache_check("QT_QPA_DEFAULT_PLATFORM" qpa_platform)

# does a window-capable backend exists for this host OS?
set(qt_has_window_gui OFF)
if (feature_gui STREQUAL "ON")
  if (WIN32 AND feature_direct2d STREQUAL "ON")
    set(qt_has_window_gui ON)
  elseif (APPLE AND qpa_platform STREQUAL "cocoa")
    set(qt_has_window_gui ON)
  elseif (UNIX AND NOT APPLE AND (feature_xcb STREQUAL "ON" OR feature_wayland_client STREQUAL "ON"))
    set(qt_has_window_gui ON)
  endif()
endif()

# fail if no GUI by default; allow explicit override with the QT_ALLOW_HEADLESS switch.
if (feature_gui STREQUAL "ON" AND NOT qt_has_window_gui AND NOT QT_ALLOW_HEADLESS)
  message(FATAL_ERROR
    "\nQt GUI configured (QT_FEATURE_gui=ON) but no window-capable platform plugin is enabled.\n"
    "Detected:\n"
    "  FEATURE_xcb=${feature_xcb}\n"
    "  FEATURE_wayland_client=${feature_wayland_client}\n"
    "  FEATURE_direct2d=${feature_direct2d}\n"
    "  QT_QPA_DEFAULT_PLATFORM=${qpa_platform}\n\n"
    "To proceed headless (e.g., offscreen/minimal/vnc), set QT_ALLOW_HEADLESS=ON\n")
elseif (feature_gui STREQUAL "ON" AND NOT qt_has_window_gui AND QT_ALLOW_HEADLESS)
  message(WARNING
    "Proceeding without a window-capable Qt backend (headless).\n"
    "Only minimal/offscreen/eglfs/linuxfb/vnc are expected.")
else()
  message(STATUS "Qt platform backend check: OK (window-capable backend present).")
endif()

message("Qt configure succeeded: ${MSG}\n")

# Local Variables:
# tab-width: 8
# mode: cmake
# indent-tabs-mode: t
# End:
